@model SmartHealthcare.MVC.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center vh-100"
     style="background: linear-gradient(135deg, #0f172a, #1e3a8a);">

    <div class="col-md-5">

        <!-- CARD -->
        <div class="card shadow-lg border-0"
             style="
                border-radius:22px;
                background-color:#1e293b;
                color:white;
                box-shadow: 0 10px 30px rgba(0,0,0,0.4);
             ">

            <!-- HEADER -->
            <div class="text-center p-4"
                 style="
                    background-color:#1e3a8a;
                    border-top-left-radius:22px;
                    border-top-right-radius:22px;
                 ">

                <h1 class="fw-bold mb-1"
                    style="font-size:32px; letter-spacing:1px;">
                    🏥 Smart Healthcare
                </h1>

                <p class="mb-0 text-light"
                   style="font-size:16px;">
                    Welcome back! Login to continue
                </p>
            </div>

            <!-- BODY -->
            <div class="card-body p-4" style="font-size:17px;">

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
                    </div>
                }

                <form asp-action="Login" method="post">
                    <input type="hidden" asp-for="ReturnUrl" />

                    <!-- EMAIL -->
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-semibold"></label>

                        <div class="input-group">
                            <span class="input-group-text"
                                  style="background-color:#334155; color:white; border:none;">
                                <i class="bi bi-envelope"></i>
                            </span>

                            <input asp-for="Email"
                                   class="form-control form-control-lg"
                                   style="background-color:#334155; color:white; border:none;"
                                   placeholder="Enter your email" />
                        </div>

                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold"></label>

                        <div class="input-group">
                            <span class="input-group-text"
                                  style="background-color:#334155; color:white; border:none;">
                                <i class="bi bi-lock"></i>
                            </span>

                            <input asp-for="Password"
                                   type="password"
                                   class="form-control form-control-lg"
                                   style="background-color:#334155; color:white; border:none;"
                                   placeholder="Enter your password" />
                        </div>

                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <!-- REMEMBER -->
                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label"></label>
                    </div>

                    <!-- BUTTON -->
                    <div class="d-grid mt-3">
                        <button type="submit"
                                class="btn btn-lg text-white"
                                style="
                                    background-color:#2563eb;
                                    border:none;
                                    border-radius:10px;
                                ">
                            <i class="bi bi-box-arrow-in-right"></i> Sign In
                        </button>
                    </div>
                </form>

                <hr class="border-secondary my-4" />

                <!-- REGISTER -->
                <div class="text-center">
                    <p class="mb-2">Don't have an account?</p>

                    <a asp-action="Register"
                       class="btn btn-outline-light"
                       style="border-radius:10px;">
                        <i class="bi bi-person-plus"></i> Register
                    </a>
                </div>

                <!-- DEMO -->
                <div class="mt-4 text-center text-muted small">
                    <p class="mb-1"><strong>Demo Credentials:</strong></p>
                    <p class="mb-0">Admin: admin@smarthealth.com / Admin@123</p>
                </div>

            </div>
        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}